generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  OWNER
  ADMIN
  COMPLIANCE_MANAGER
  SECURITY_MANAGER
  HR_MANAGER
  AUDITOR
  EMPLOYEE
  READ_ONLY
}

enum ImplementationStatus {
  NOT_STARTED
  IN_PROGRESS
  IMPLEMENTED
  NOT_APPLICABLE
}

enum QuestionnaireStatus {
  DRAFT
  SUBMITTED
}

enum EvidenceStatus {
  PENDING_UPLOAD
  PROCESSING
  PENDING_REVIEW
  APPROVED
  REJECTED
  EXPIRED
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
}

enum RiskLikelihood {
  LOW
  MEDIUM
  HIGH
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RiskTreatmentStatus {
  OPEN
  IN_PROGRESS
  MITIGATED
  ACCEPTED
}

enum PolicyStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum AssignmentStatus {
  ASSIGNED
  COMPLETED
}

enum VendorRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}
enum AssessmentStatus {
  DRAFT
  IN_REVIEW
  COMPLETED
}
enum AuditStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}
enum FindingStatus {
  OPEN
  REVIEWED
  RESOLVED
}
enum FindingSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model User {
  id           String                   @id @default(uuid()) @db.Uuid
  email        String                   @unique
  name         String
  passwordHash String
  memberships OrganizationMembership[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model Organization {
  id           String                   @id @default(uuid()) @db.Uuid
  name         String
  slug         String                   @unique
  memberships  OrganizationMembership[]
  frameworks   OrganizationFramework[]
  controls     ControlImplementation[]
  activity     ActivityEvent[]
  questionnaireRuns QuestionnaireRun[]
  evidence     EvidenceRecord[]
  tasks        Task[]
  risks        Risk[]
  employees    Employee[]
  policies     Policy[]
  trainingCourses TrainingCourse[]
  vendors      Vendor[]
  audits       Audit[]
  workspaceItems WorkspaceItemState[]
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
}

model WorkspaceItemState {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  frameworkId    String
  itemId         String
  itemType       String?
  state          Json
  version        Int          @default(1)
  createdBy      String       @db.Uuid
  updatedBy      String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([organizationId, frameworkId, itemId])
  @@index([organizationId, frameworkId])
}

model Vendor {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  category       String?
  website        String?
  ownerName      String?
  risk           VendorRisk   @default(LOW)
  nextReviewDate DateTime?
  active         Boolean      @default(true)
  createdBy      String       @db.Uuid
  updatedBy      String       @db.Uuid
  version        Int          @default(1)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assessments    VendorAssessment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([organizationId, name])
  @@index([organizationId, risk])
}

model VendorAssessment {
  id          String           @id @default(uuid()) @db.Uuid
  vendorId    String           @db.Uuid
  status      AssessmentStatus @default(DRAFT)
  score       Int?
  summary     String?
  assessedBy  String?          @db.Uuid
  completedAt DateTime?
  responses   Json?
  vendor      Vendor           @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  @@index([vendorId, status])
}

model Audit {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  frameworkId    String
  name           String
  auditType      String?
  status         AuditStatus  @default(PLANNED)
  auditorName    String?
  startDate      DateTime?
  targetDate     DateTime?
  completedAt    DateTime?
  createdBy      String       @db.Uuid
  updatedBy      String       @db.Uuid
  version        Int          @default(1)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  findings       AuditFinding[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@index([organizationId, frameworkId, status])
}

model AuditFinding {
  id            String          @id @default(uuid()) @db.Uuid
  auditId       String          @db.Uuid
  externalId    String?
  name          String
  description   String?
  category      String?
  domain        String?
  relatedItemId String?
  severity      FindingSeverity @default(MEDIUM)
  status        FindingStatus   @default(OPEN)
  ownerName     String?
  dueDate       DateTime?
  reviewerName  String?
  reviewerId    String?         @db.Uuid
  reviewComments String?
  reviewedAt    DateTime?
  resolvedAt    DateTime?
  resolvedBy    String?         @db.Uuid
  version       Int             @default(1)
  audit         Audit           @relation(fields: [auditId], references: [id], onDelete: Cascade)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  @@unique([auditId, externalId])
  @@index([auditId, status, severity])
}

model Employee {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  name           String
  email          String
  jobRole        String?
  employmentType String?
  hasAccess      Boolean      @default(true)
  startDate      DateTime?
  endDate        DateTime?
  tags           String[]
  backgroundCheckCompletedAt DateTime?
  createdBy      String       @db.Uuid
  updatedBy      String       @db.Uuid
  version        Int          @default(1)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  policyAssignments PolicyAssignment[]
  trainingAssignments TrainingAssignment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([organizationId, email])
  @@index([organizationId, hasAccess])
}

model Policy {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  frameworkId    String
  sourcePolicyId String?
  name           String
  description    String?
  ownerName      String?
  versionLabel   String       @default("1.0")
  status         PolicyStatus @default(DRAFT)
  effectiveDate  DateTime?
  reviewDate     DateTime?
  custom         Boolean      @default(true)
  createdBy      String       @db.Uuid
  updatedBy      String       @db.Uuid
  version        Int          @default(1)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    PolicyAssignment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([organizationId, frameworkId, sourcePolicyId])
  @@index([organizationId, frameworkId, status])
}

model PolicyAssignment {
  id             String           @id @default(uuid()) @db.Uuid
  policyId       String           @db.Uuid
  employeeId     String           @db.Uuid
  assignedBy     String           @db.Uuid
  acknowledgedAt DateTime?
  acknowledgedBy String?          @db.Uuid
  policy         Policy           @relation(fields: [policyId], references: [id], onDelete: Cascade)
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  @@unique([policyId, employeeId])
  @@index([employeeId])
}

model TrainingCourse {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  externalId     String?
  name           String
  description    String?
  relatedFrameworks String[]
  dueDate        DateTime?
  custom         Boolean      @default(true)
  createdBy      String       @db.Uuid
  updatedBy      String       @db.Uuid
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignments    TrainingAssignment[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  @@unique([organizationId, externalId])
}

model TrainingAssignment {
  id             String           @id @default(uuid()) @db.Uuid
  courseId       String           @db.Uuid
  employeeId     String           @db.Uuid
  assignedBy     String           @db.Uuid
  status         AssignmentStatus @default(ASSIGNED)
  completedAt    DateTime?
  completedBy    String?          @db.Uuid
  course         TrainingCourse   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  employee       Employee         @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  @@unique([courseId, employeeId])
  @@index([employeeId, status])
}

model OrganizationMembership {
  id             String         @id @default(uuid()) @db.Uuid
  organizationId String         @db.Uuid
  userId         String         @db.Uuid
  role           MembershipRole @default(EMPLOYEE)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([organizationId, userId])
  @@index([userId])
}

model Framework {
  id          String                   @id
  slug        String                   @unique
  name        String
  version     String
  description String?
  metadata    Json?
  controls    Control[]
  organizations OrganizationFramework[]
  questionnaireRuns QuestionnaireRun[]
  evidence      EvidenceRecord[]
  tasks         Task[]
  risks         Risk[]
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
}

model Task {
  id               String       @id @default(uuid()) @db.Uuid
  organizationId   String       @db.Uuid
  frameworkId      String
  sourceTemplateId String?
  itemId           String?
  itemType         String?
  category         String?
  title            String
  description      String?
  status           TaskStatus   @default(OPEN)
  priority         String?
  ownerUserId      String?      @db.Uuid
  ownerName        String?
  dueDate          DateTime?
  completedAt      DateTime?
  completedBy      String?      @db.Uuid
  createdBy        String       @db.Uuid
  updatedBy        String       @db.Uuid
  version          Int          @default(1)
  organization     Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  framework        Framework    @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@unique([organizationId, frameworkId, sourceTemplateId])
  @@index([organizationId, frameworkId, status])
}

model Risk {
  id               String              @id @default(uuid()) @db.Uuid
  organizationId   String              @db.Uuid
  frameworkId      String
  sourceRiskId     String?
  name             String
  description      String?
  domain           String?
  relatedControls  String[]
  ownerUserId      String?             @db.Uuid
  ownerName        String?
  likelihood       RiskLikelihood      @default(MEDIUM)
  impact           RiskLikelihood      @default(MEDIUM)
  level            RiskLevel           @default(MEDIUM)
  treatmentStatus  RiskTreatmentStatus @default(OPEN)
  reviewDate       DateTime?
  custom           Boolean             @default(true)
  createdBy        String              @db.Uuid
  updatedBy        String              @db.Uuid
  version          Int                 @default(1)
  organization     Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  framework        Framework           @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  @@unique([organizationId, frameworkId, sourceRiskId])
  @@index([organizationId, frameworkId, treatmentStatus])
}

model Control {
  id             String                  @id @default(uuid()) @db.Uuid
  frameworkId    String
  externalId     String
  title          String
  category       String?
  objective      String?
  description    String?
  priority       String?
  guidance       String?
  metadata       Json?
  framework      Framework               @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  implementations ControlImplementation[]
  evidenceMappings EvidenceMapping[]
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@unique([frameworkId, externalId])
  @@index([frameworkId, category])
}

model QuestionnaireRun {
  id             String              @id @default(uuid()) @db.Uuid
  organizationId String              @db.Uuid
  frameworkId    String
  status         QuestionnaireStatus @default(DRAFT)
  submittedAt    DateTime?
  submittedBy    String?             @db.Uuid
  version        Int                 @default(1)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  framework      Framework           @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  answers        QuestionnaireAnswer[]
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@index([organizationId, frameworkId])
}

model QuestionnaireAnswer {
  id         String           @id @default(uuid()) @db.Uuid
  runId      String           @db.Uuid
  questionId String
  value      Json
  answeredBy String           @db.Uuid
  run        QuestionnaireRun @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@unique([runId, questionId])
}

model EvidenceRecord {
  id               String          @id @default(uuid()) @db.Uuid
  organizationId   String          @db.Uuid
  frameworkId      String
  title             String
  description       String?
  status            EvidenceStatus @default(PENDING_UPLOAD)
  ownerUserId       String?         @db.Uuid
  currentVersionId  String?         @db.Uuid
  expiresAt         DateTime?
  tags              String[]
  createdBy         String          @db.Uuid
  updatedBy         String          @db.Uuid
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  framework         Framework       @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  versions           EvidenceVersion[]
  mappings           EvidenceMapping[]
  comments           EvidenceComment[]
  reviewerId         String?         @db.Uuid
  reviewReason       String?
  reviewedAt         DateTime?
  deletedAt          DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([organizationId, frameworkId, status])
}

model EvidenceComment {
  id         String         @id @default(uuid()) @db.Uuid
  evidenceId String         @db.Uuid
  text       String
  userId     String         @db.Uuid
  userName   String
  evidence   EvidenceRecord @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())
  @@index([evidenceId, createdAt])
}

model EvidenceVersion {
  id           String         @id @default(uuid()) @db.Uuid
  evidenceId   String         @db.Uuid
  version      Int
  fileName     String
  contentType  String
  fileSize     Int
  objectKey    String
  checksum     String?
  uploadedBy   String         @db.Uuid
  uploadedAt   DateTime?
  evidence     EvidenceRecord @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  createdAt    DateTime       @default(now())

  @@unique([evidenceId, version])
}

model EvidenceMapping {
  id         String         @id @default(uuid()) @db.Uuid
  evidenceId String         @db.Uuid
  controlId  String         @db.Uuid
  evidence   EvidenceRecord @relation(fields: [evidenceId], references: [id], onDelete: Cascade)
  control    Control        @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdAt  DateTime       @default(now())

  @@unique([evidenceId, controlId])
  @@index([controlId])
}

model OrganizationFramework {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  frameworkId    String
  active         Boolean      @default(true)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  framework      Framework    @relation(fields: [frameworkId], references: [id], onDelete: Restrict)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, frameworkId])
  @@index([organizationId])
}

model ControlImplementation {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @db.Uuid
  controlId      String               @db.Uuid
  status         ImplementationStatus @default(NOT_STARTED)
  ownerUserId    String?              @db.Uuid
  notes          String?
  targetDate     DateTime?
  version        Int                  @default(1)
  createdBy      String               @db.Uuid
  updatedBy      String               @db.Uuid
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  control        Control              @relation(fields: [controlId], references: [id], onDelete: Cascade)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([organizationId, controlId])
  @@index([organizationId, status])
}

model ActivityEvent {
  id             String       @id @default(uuid()) @db.Uuid
  organizationId String       @db.Uuid
  actorUserId    String?      @db.Uuid
  action         String
  entityType     String
  entityId       String
  metadata       Json?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([organizationId, createdAt])
}
